{
  "name": "niraa-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server/server.js",
    "build": "npm install --prefix server && npm install --prefix client && npm run build --prefix client",
    "dev": "concurrently \"npm:dev-server\" \"npm:dev-client\" \"npm:dev-admin\"",
    "dev-server": "npm --prefix server run dev",
    "dev-client": "npm --prefix client run dev",
    "dev-admin": "npm --prefix admin run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cloudinary": "^1.41.3",
    "firebase": "^12.12.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0"
  }
}
